# ── Backend Configuration (backend/.env) ──
PORT=3000
GROQ_API_KEY=your_groq_api_key_here
# Absolute path to the backend/projects directory on the host machine
HOST_PROJECT_PATH=/absolute/path/to/Code-Sandbox-Clone/backend/projects
SANDBOX_IMAGE=sandbox

# ── Frontend Configuration (frontend/.env) ──
VITE_BACKEND_URL=http://localhost:3000
VITE_TERMINAL_URL=localhost:3000
