# ── Server Configuration ──
PORT=3000
NODE_ENV=development

# ── AI Agent (Groq) ──
# Get your API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Docker Sandbox ──
# Absolute path to the backend/projects directory on the host machine
HOST_PROJECT_PATH=/absolute/path/to/Code-Sandbox-Clone/backend/projects
# Name of the Docker image used for sandboxed containers
SANDBOX_IMAGE=sandbox
